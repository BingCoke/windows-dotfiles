{{- if eq .chezmoi.os "windows" -}}
# chezmoi:template:remove-space
$ErrorActionPreference = "Stop"

function Ensure-DirSymlink {
    param(
        [Parameter(Mandatory)] [string]$Target,
        [Parameter(Mandatory)] [string]$Link
    )

    $Target = [System.Environment]::ExpandEnvironmentVariables($Target)
    $Link = [System.Environment]::ExpandEnvironmentVariables($Link)

    if (Test-Path -LiteralPath $Link) {
        $existing = Get-Item -LiteralPath $Link -Force
        if ($existing.LinkType -eq "SymbolicLink" -and $existing.Target -eq $Target) {
            Write-Host "OK: $Link -> $Target"
            return
        }

        Remove-Item -LiteralPath $Link -Recurse -Force
    }

    $parentDir = Split-Path -Path $Link -Parent
    New-Item -ItemType Directory -Path $parentDir -Force | Out-Null
    New-Item -ItemType SymbolicLink -Path $Link -Target $Target | Out-Null
    Write-Host "Created: $Link -> $Target"
}

function Ensure-UserEnvironmentVariable {
    param(
        [Parameter(Mandatory)] [string]$Name,
        [Parameter(Mandatory)] [string]$Value
    )

    $currentValue = [Environment]::GetEnvironmentVariable($Name, "User")

    if ($currentValue -eq $Value) {
        Write-Host "OK: $Name=$Value"
        return
    }

    [Environment]::SetEnvironmentVariable($Name, $Value, "User")
    Write-Host "Set: $Name=$Value"
}

$xdgConfig = Join-Path $env:USERPROFILE ".config"
$xdgData = Join-Path $env:USERPROFILE ".local\share"
$xdgState = Join-Path $env:USERPROFILE ".local\state"
$xdgCache = Join-Path $env:USERPROFILE ".cache"
$local = $env:LOCALAPPDATA
$roaming = $env:APPDATA

$zellijConfigDir = Join-Path $xdgConfig "zellij"
$scriptsDir = Join-Path $xdgConfig "script"
$yaziConfigHome = Join-Path $xdgConfig "yazi"

Write-Host "`n[xdg env]"
Ensure-UserEnvironmentVariable -Name "XDG_CONFIG_HOME" -Value $xdgConfig
Ensure-UserEnvironmentVariable -Name "XDG_DATA_HOME" -Value $xdgData
Ensure-UserEnvironmentVariable -Name "XDG_STATE_HOME" -Value $xdgState
Ensure-UserEnvironmentVariable -Name "XDG_CACHE_HOME" -Value $xdgCache

Write-Host "`n[zellij env]"
Ensure-UserEnvironmentVariable -Name "ZELLIJ_CONFIG_DIR" -Value $zellijConfigDir

Write-Host "`n[shell/editor env]"
Ensure-UserEnvironmentVariable -Name "EDITOR" -Value "nvim"
Ensure-UserEnvironmentVariable -Name "YAZI_CONFIG_HOME" -Value $yaziConfigHome

$links = @(
    @{ Name = "alacritty"; Target = Join-Path $xdgConfig "alacritty"; Link = Join-Path $roaming "alacritty" }
)

foreach ($item in $links) {
    Write-Host "`n[$($item.Name)]"
    Ensure-DirSymlink -Target $item.Target -Link $item.Link
}

Write-Host "`n=== Done ===" -ForegroundColor Cyan


{{- end }}
